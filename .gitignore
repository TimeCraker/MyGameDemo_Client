# ==========================================
# 1. Unity 核心缓存 (必须忽略，否则就是上万个文件)
# ==========================================
/[Ll]ibrary/
/[Tt]emp/
/[Oo]bj/
/[Bb]uild/
/[Bb]uilds/
/[Ll]ogs/
/[Uu]ser[Ss]ettings/
.utmp/

# ==========================================
# 2. 外部工具生成的工程文件 (VS/Rider/Gradle)
# ==========================================
# 这些文件在不同的电脑上会重新生成，传了反而会导致冲突
*.csproj
*.sln
*.suo
*.user
*.unityproj
.vs/
.gradle/
*.pdb
*.mdb

# ==========================================
# 3. 资源管理与 TMP (这是你今天乱传的主因)
# ==========================================
# TextMesh Pro 的基础资源可以通过 Unity 菜单一键导入，没必要放进 Git
/[Aa]ssets/TextMesh\ Pro/

# 如果你以后用了 Addressables，提前防范
/ServerData/
/[Aa]ssets/StreamingAssets/aa/*

# ==========================================
# 4. 构建产物 (你自己打包出的 .exe)
# ==========================================
*.apk
*.exe
*.app
/[Bb]uild/

# ==========================================
# 5. 其他杂项
# ==========================================
*.log
sysinfo.txt
mono_crash.*